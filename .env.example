# 必填：JWT 签名密钥（至少 32 位随机字符串）
# 生成方式：openssl rand -hex 32
JWT_SECRET=your-strong-random-secret-here-at-least-32-chars

# 可选：对外访问端口（默认 8787）
# PORT=8787

# 可选：WebAuthn / Passkey 设置（需要 HTTPS 域名才能使用）
# WEBAUTHN_RP_ID=yourdomain.com
# WEBAUTHN_RP_NAME=PassVault
# WEBAUTHN_ALLOWED_ORIGINS=https://yourdomain.com
